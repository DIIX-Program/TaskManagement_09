@model TaskManagement.Web.Models.ViewModels.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join Us - Task Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'starbucks-green': '#006241',
                        'house-green': '#1e3932',
                        'gold': '#cba258',
                        'warm-neutral': '#f2f0eb',
                        'ceramic': '#d4e1d1',
                        'text-black': '#000000',
                        'text-black-soft': '#000000de',
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="bg-ceramic min-h-screen flex items-center justify-center p-6">
    <div class="max-w-md w-full">
        <!-- Logo -->
        <div class="flex flex-col items-center mb-8">
            <div class="w-16 h-16 bg-starbucks-green rounded-full flex items-center justify-center mb-4 shadow-lg">
                <i class="fa-solid fa-check text-white text-3xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-starbucks-green tracking-tight">Tạo tài khoản</h1>
            <p class="text-text-black-soft mt-2 italic">Bắt đầu hành trình quản lý công việc tốt hơn.</p>
        </div>

        <!-- Register Card -->
        <div class="card shadow-xl p-8">
            <h2 class="text-2xl font-bold text-text-black mb-6">Đăng ký ngay</h2>
            
            <form asp-action="Register" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

                <div class="space-y-1">
                    <label asp-for="FullName" class="text-sm font-semibold text-text-black">Họ và tên</label>
                    <input asp-for="FullName" class="w-full px-4 py-3 rounded-lg border border-black/[0.1] focus:border-starbucks-green focus:ring-2 focus:ring-starbucks-green/20 outline-none transition-all" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="FullName" class="text-red-500 text-xs font-bold"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="Email" class="text-sm font-semibold text-text-black">Địa chỉ Email</label>
                    <input asp-for="Email" class="w-full px-4 py-3 rounded-lg border border-black/[0.1] focus:border-starbucks-green focus:ring-2 focus:ring-starbucks-green/20 outline-none transition-all" placeholder="name@company.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs font-bold"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="Password" class="text-sm font-semibold text-text-black">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="w-full px-4 py-3 rounded-lg border border-black/[0.1] focus:border-starbucks-green focus:ring-2 focus:ring-starbucks-green/20 outline-none transition-all" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs font-bold"></span>
                </div>

                <div class="text-xs text-text-black-soft py-2">
                    Bằng việc tham gia, bạn đồng ý với <a href="#" class="text-accent-green hover:underline">Điều khoản dịch vụ</a> và <a href="#" class="text-accent-green hover:underline">Chính sách bảo mật</a> của chúng tôi.
                </div>

                <button type="submit" class="w-full btn-primary py-4 text-lg">Tạo tài khoản</button>
            </form>

            <div class="mt-8 pt-6 border-t border-black/[0.06] text-center">
                <p class="text-text-black-soft text-sm font-medium">
                    Đã là thành viên? 
                    <a asp-action="Login" class="text-accent-green font-bold hover:underline">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</body>
</html>
