@model IEnumerable<TaskManagement.Web.Services.UserViewModel>

<div class="space-y-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 bg-white p-8 rounded-[24px] shadow-soft border border-black/[0.03]">
        <div>
            <h1 class="text-4xl font-extrabold text-house-green">Đội ngũ đối tác</h1>
            <p class="text-text-black-soft font-medium">Đội ngũ gồm @Model.Count() chuyên gia đang cùng nhau xây dựng thành công.</p>
        </div>
        <div class="flex gap-4">
            @if (Context.Session.GetString("Role") == "Admin")
            {
                <button onclick="openInviteModal()" class="btn-gold flex items-center gap-2">
                    <i class="fa-solid fa-user-plus"></i>
                    <span>Thêm nhân viên mới</span>
                </button>
            }
            @if (Context.Session.GetString("Role") != "Employee")
            {
                <button onclick="openGlobalNotificationModal()" class="btn-primary flex items-center gap-2">
                    <i class="fa-solid fa-paper-plane"></i>
                    <span>Gửi thông báo</span>
                </button>
            }
        </div>
    </div>

    <!-- Filters -->
    <div class="flex gap-4 items-center bg-white p-4 rounded-xl border border-black/[0.06] shadow-sm">
        <div class="flex-1 relative">
            <i class="fa-solid fa-search absolute left-4 top-1/2 -translate-y-1/2 text-text-black-soft"></i>
            <input type="text" id="partnerSearch" placeholder="Search partners by name, email or role..." class="w-full pl-12 pr-4 py-2 bg-ceramic/50 rounded-lg outline-none focus:ring-4 focus:ring-starbucks-green/10 font-medium" />
        </div>
        <div class="flex gap-2">
            <button onclick="filterTeam('All', this)" class="px-4 py-2 bg-starbucks-green text-white rounded-lg text-sm font-bold shadow-md shadow-starbucks-green/20 filter-btn" data-role="All">All</button>
            <button onclick="filterTeam('Admin', this)" class="px-4 py-2 bg-white text-text-black-soft hover:bg-ceramic rounded-lg text-sm font-bold border border-black/[0.06] transition-colors filter-btn" data-role="Admin">Admins</button>
            <button onclick="filterTeam('Manager', this)" class="px-4 py-2 bg-white text-text-black-soft hover:bg-ceramic rounded-lg text-sm font-bold border border-black/[0.06] transition-colors filter-btn" data-role="Manager">Managers</button>
            <button onclick="filterTeam('Employee', this)" class="px-4 py-2 bg-white text-text-black-soft hover:bg-ceramic rounded-lg text-sm font-bold border border-black/[0.06] transition-colors filter-btn" data-role="Employee">Employees</button>
        </div>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="teamGrid">
        @foreach (var user in Model)
        {
            <div class="card group hover:-translate-y-2 hover:border-starbucks-green partner-card" data-role="@user.RoleName" data-name="@user.FullName.ToLower()" data-email="@user.Email.ToLower()">
                <div class="flex flex-col items-center text-center">
                    <div class="relative mb-6">
                        <div class="w-24 h-24 rounded-full bg-gradient-to-br from-light-green to-ceramic flex items-center justify-center text-3xl font-black text-starbucks-green shadow-inner">
                            @user.FullName.Substring(0, 1)
                        </div>
                        <div class="absolute bottom-1 right-1 w-6 h-6 bg-green-500 border-4 border-white rounded-full shadow-sm"></div>
                    </div>
                    
                    <h3 class="text-xl font-bold text-house-green group-hover:text-starbucks-green transition-colors">@user.FullName</h3>
                    <p class="text-xs font-black uppercase tracking-[0.2em] text-gold mb-4">@user.RoleName</p>
                    
                    <div class="w-full space-y-3 pt-4 border-t border-black/[0.04]">
                        <div class="flex items-center justify-center gap-2 text-sm text-text-black-soft font-medium">
                            <i class="fa-solid fa-envelope opacity-50"></i>
                            <span>@user.Email</span>
                        </div>
                    </div>
                    
                    <div class="flex gap-2 mt-6">
                        @if (Context.Session.GetString("Role") != "Employee")
                        {
                            <button onclick="openNotificationModal(@user.UserId, '@user.FullName')" class="w-10 h-10 rounded-full bg-ceramic/50 text-house-green hover:bg-starbucks-green hover:text-white transition-all tooltip" title="Gửi thông báo">
                                <i class="fa-solid fa-bell"></i>
                            </button>
                        }
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <button onclick="openRoleModal(@user.UserId, '@user.RoleName')" class="w-10 h-10 rounded-full bg-ceramic/50 text-house-green hover:bg-accent-green hover:text-white transition-all tooltip" title="Phân quyền">
                                <i class="fa-solid fa-user-shield"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <!-- Invite Modal -->
    <div id="inviteModal" class="fixed inset-0 bg-house-green/60 backdrop-blur-sm z-[100] hidden items-center justify-center p-6">
        <div class="bg-white rounded-[24px] shadow-2xl w-full max-w-md p-8">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-2xl font-bold text-house-green">Mời nhân viên mới</h3>
                <button onclick="closeInviteModal()" class="text-text-black-soft hover:text-house-green text-2xl"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="text-xs font-black uppercase tracking-widest text-text-black-soft">Email nhân viên</label>
                    <input type="email" id="inviteEmail" placeholder="partner@starbucks.com" class="w-full p-4 bg-ceramic/50 rounded-xl outline-none focus:ring-4 focus:ring-starbucks-green/10 font-medium" />
                </div>
                <button onclick="handleInvite()" class="btn-gold w-full py-4 text-lg">Gửi lời mời</button>
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div id="notificationModal" class="fixed inset-0 bg-house-green/60 backdrop-blur-sm z-[100] hidden items-center justify-center p-6">
        <div class="bg-white rounded-[24px] shadow-2xl w-full max-w-md p-8">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-2xl font-bold text-house-green">Gửi thông báo</h3>
                <button onclick="closeNotificationModal()" class="text-text-black-soft hover:text-house-green text-2xl"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="space-y-6">
                <p class="text-sm font-medium text-text-black-soft">Gửi đến: <span id="notifTarget" class="font-bold text-starbucks-green"></span></p>
                <input type="hidden" id="notifUserId" />
                <div class="space-y-2">
                    <label class="text-xs font-black uppercase tracking-widest text-text-black-soft">Nội dung thông báo</label>
                    <textarea id="notifMessage" rows="4" class="w-full p-4 bg-ceramic/50 rounded-xl outline-none focus:ring-4 focus:ring-starbucks-green/10 font-medium" placeholder="Nhập nội dung thông báo..."></textarea>
                </div>
                <button onclick="handleSendNotification()" class="btn-primary w-full py-4">Gửi ngay</button>
            </div>
        </div>
    </div>

    <!-- Role Modal -->
    <div id="roleModal" class="fixed inset-0 bg-house-green/60 backdrop-blur-sm z-[100] hidden items-center justify-center p-6">
        <div class="bg-white rounded-[24px] shadow-2xl w-full max-w-md p-8">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-2xl font-bold text-house-green">Phân quyền người dùng</h3>
                <button onclick="closeRoleModal()" class="text-text-black-soft hover:text-house-green text-2xl"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="space-y-6">
                <input type="hidden" id="roleUserId" />
                <div class="space-y-2">
                    <label class="text-xs font-black uppercase tracking-widest text-text-black-soft">Chọn vai trò</label>
                    <select id="roleSelect" class="w-full p-4 bg-ceramic/50 rounded-xl outline-none focus:ring-4 focus:ring-starbucks-green/10 font-medium">
                        <option value="Admin">Admin</option>
                        <option value="Manager">Manager</option>
                        <option value="Employee">Employee</option>
                    </select>
                </div>
                <button onclick="handleUpdateRole()" class="btn-primary w-full py-4">Cập nhật vai trò</button>
            </div>
        </div>
    </div>

    <script>
        function filterTeam(role, element) {
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-starbucks-green', 'text-white', 'shadow-md', 'shadow-starbucks-green/20');
                btn.classList.add('bg-white', 'text-text-black-soft');
            });
            element.classList.remove('bg-white', 'text-text-black-soft');
            element.classList.add('bg-starbucks-green', 'text-white', 'shadow-md', 'shadow-starbucks-green/20');

            applyFilters();
        }

        function applyFilters() {
            const searchTerm = document.getElementById('partnerSearch').value.toLowerCase();
            const activeBtn = document.querySelector('.filter-btn.bg-starbucks-green');
            const activeRole = activeBtn ? activeBtn.getAttribute('data-role') : 'All';

            document.querySelectorAll('.partner-card').forEach(card => {
                const role = card.getAttribute('data-role');
                const name = card.getAttribute('data-name');
                const email = card.getAttribute('data-email');

                const matchesSearch = name.includes(searchTerm) || email.includes(searchTerm) || role.toLowerCase().includes(searchTerm);
                const matchesRole = activeRole === 'All' || role === activeRole;

                if (matchesSearch && matchesRole) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        async function handleInvite() {
            const email = document.getElementById('inviteEmail').value;
            if(!email) return alert('Vui lòng nhập email');

            const response = await fetch('/Team/Invite', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ email })
            });

            if(response.ok) {
                alert('Đã thêm nhân viên thành công (Mật khẩu mặc định: Starbucks@123)');
                location.reload();
            } else {
                const error = await response.text();
                alert('Lỗi: ' + error);
            }
        }

        function openInviteModal() { document.getElementById('inviteModal').classList.replace('hidden', 'flex'); }
        function closeInviteModal() { document.getElementById('inviteModal').classList.replace('flex', 'hidden'); }

        function openNotificationModal(userId, fullName) {
            document.getElementById('notifUserId').value = userId;
            document.getElementById('notifTarget').innerText = fullName;
            document.getElementById('notificationModal').classList.replace('hidden', 'flex');
        }
        function closeNotificationModal() { document.getElementById('notificationModal').classList.replace('flex', 'hidden'); }

        async function handleSendNotification() {
            const userId = document.getElementById('notifUserId').value;
            const message = document.getElementById('notifMessage').value;
            if(!message) return alert('Vui lòng nhập nội dung');

            const response = await fetch('/Notifications/Send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId, message })
            });

            if(response.ok) {
                alert('Đã gửi thông báo thành công');
                closeNotificationModal();
            } else {
                alert('Lỗi khi gửi thông báo');
            }
        }

        function openRoleModal(userId, currentRole) {
            document.getElementById('roleUserId').value = userId;
            document.getElementById('roleSelect').value = currentRole;
            document.getElementById('roleModal').classList.replace('hidden', 'flex');
        }
        function closeRoleModal() { document.getElementById('roleModal').classList.replace('flex', 'hidden'); }

        async function handleUpdateRole() {
            const userId = document.getElementById('roleUserId').value;
            const roleName = document.getElementById('roleSelect').value;

            const response = await fetch('/Team/UpdateRole', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ userId, roleName })
            });

            if(response.ok) {
                alert('Cập nhật vai trò thành công');
                location.reload();
            } else {
                alert('Lỗi khi cập nhật vai trò');
            }
        }

        document.getElementById('partnerSearch').addEventListener('input', applyFilters);
    </script>
}
