@model TaskManagement.Web.Services.CreateTaskViewModel

<div class="max-w-3xl mx-auto space-y-8">
    <div class="bg-white p-8 rounded-[24px] shadow-soft border border-black/[0.03]">
        <nav class="flex text-xs font-bold uppercase tracking-widest text-text-black-soft gap-2 mb-4">
            <a asp-action="Index" class="hover:text-starbucks-green transition-colors">Tasks</a>
            <span>/</span>
            <span class="text-starbucks-green">Create New</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-house-green">Brew a New Task</h1>
        <p class="text-text-black-soft font-medium">Define the details and assign it to a partner.</p>
    </div>

    <form asp-action="Create" method="post" class="card space-y-8">
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

        <!-- Task Title -->
        <div class="space-y-2">
            <label asp-for="Title" class="text-xs font-black uppercase tracking-widest text-house-green">Task Title</label>
            <input asp-for="Title" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold" placeholder="e.g. Implement API security" />
            <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
        </div>

        <!-- Project & Assignee -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                <label asp-for="ProjectId" class="text-xs font-black uppercase tracking-widest text-house-green">Project</label>
                <select asp-for="ProjectId" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold">
                    <option disabled selected>Select a project...</option>
                    @foreach (var p in (IEnumerable<TaskManagement.Web.Services.ProjectViewModel>)ViewBag.Projects)
                    {
                        <option value="@p.ProjectId">@p.Name</option>
                    }
                </select>
                <span asp-validation-for="ProjectId" class="text-red-500 text-xs"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="AssignedTo" class="text-xs font-black uppercase tracking-widest text-house-green">Assign To Partner</label>
                <select asp-for="AssignedTo" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold">
                    <option value="">Unassigned</option>
                    @foreach (var u in (IEnumerable<TaskManagement.Web.Services.UserViewModel>)ViewBag.Users)
                    {
                        <option value="@u.UserId">@u.FullName (@u.RoleName)</option>
                    }
                </select>
                <span asp-validation-for="AssignedTo" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <!-- Priority & Deadline -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                <label asp-for="Priority" class="text-xs font-black uppercase tracking-widest text-house-green">Priority Level</label>
                <select asp-for="Priority" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold">
                    <option value="1">Low - Calm Brew</option>
                    <option value="2">Medium - Balanced Roast</option>
                    <option value="3">High - Double Shot Espresso</option>
                </select>
                <span asp-validation-for="Priority" class="text-red-500 text-xs"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Deadline" class="text-xs font-black uppercase tracking-widest text-house-green">Target Deadline</label>
                <input asp-for="Deadline" type="date" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold" />
                <span asp-validation-for="Deadline" class="text-red-500 text-xs"></span>
            </div>
        </div>

        <!-- Description -->
        <div class="space-y-2">
            <label asp-for="Description" class="text-xs font-black uppercase tracking-widest text-house-green">Description & Requirements</label>
            <textarea asp-for="Description" rows="4" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-medium" placeholder="Describe the task requirements..."></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
        </div>

        <div class="flex gap-4 pt-6">
            <button type="submit" class="btn-primary flex-1 py-4 text-lg">Create Task</button>
            <a asp-action="Index" class="btn-outline flex-1 py-4 text-lg text-center">Cancel</a>
        </div>
    </form>
</div>
