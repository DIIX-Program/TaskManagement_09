@model TaskManagement.Web.Services.ProjectViewModel

<div class="max-w-2xl mx-auto">
    <div class="bg-white p-10 rounded-[32px] shadow-soft border border-black/[0.03]">
        <div class="mb-10 text-center">
            <div class="w-16 h-16 bg-starbucks-green rounded-2xl flex items-center justify-center text-white text-2xl mx-auto mb-4 shadow-lg">
                <i class="fa-solid fa-folder-plus"></i>
            </div>
            <h1 class="text-3xl font-extrabold text-house-green">Brew a New Project</h1>
            <p class="text-text-black-soft font-medium">Define your goals and start the collaboration roast.</p>
        </div>

        <form asp-action="Create" method="post" class="space-y-6">
            <div class="space-y-2">
                <label asp-for="Name" class="text-xs font-black uppercase tracking-widest text-text-black-soft">Project Name</label>
                <input asp-for="Name" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold" placeholder="e.g., Seasonal Blend Campaign" required />
            </div>

            <div class="space-y-2">
                <label asp-for="Description" class="text-xs font-black uppercase tracking-widest text-text-black-soft">Description</label>
                <textarea asp-for="Description" rows="4" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold" placeholder="What's this project about?"></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="StartDate" class="text-xs font-black uppercase tracking-widest text-text-black-soft">Start Date</label>
                    <input asp-for="StartDate" type="date" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold" />
                </div>
                <div class="space-y-2">
                    <label asp-for="EndDate" class="text-xs font-black uppercase tracking-widest text-text-black-soft">End Date</label>
                    <input asp-for="EndDate" type="date" class="w-full p-4 bg-ceramic/30 rounded-xl border border-black/[0.06] outline-none focus:ring-4 focus:ring-starbucks-green/10 font-semibold" />
                </div>
            </div>

            <div class="pt-6 flex gap-4">
                <button type="submit" class="flex-1 btn-primary py-4">Create Project</button>
                <a asp-action="Index" class="flex-1 px-6 py-4 rounded-pill border-2 border-house-green text-house-green font-bold text-center hover:bg-house-green hover:text-white transition-all">Cancel</a>
            </div>
        </form>
    </div>
</div>
