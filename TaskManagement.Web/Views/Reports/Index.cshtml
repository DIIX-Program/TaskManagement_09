@model IEnumerable<TaskManagement.Web.Services.UserWorkloadViewModel>

<div class="space-y-8">
    <div class="bg-white p-8 rounded-[32px] shadow-soft border border-black/[0.03] flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-extrabold text-house-green">Báo cáo hiệu suất nhân sự</h1>
            <p class="text-text-black-soft font-medium">Theo dõi khối lượng công việc và tốc độ hoàn thành của đội ngũ.</p>
        </div>
        <div class="flex gap-4">
            <button onclick="window.print()" class="px-6 py-3 bg-ceramic rounded-xl font-bold text-house-green hover:bg-ceramic/80 transition-all">
                <i class="fa-solid fa-print mr-2"></i> Xuất báo cáo
            </button>
        </div>
    </div>

    <!-- Summary Widgets -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card bg-starbucks-green text-white">
            <p class="text-xs font-black uppercase tracking-widest opacity-80">Tổng nhân sự</p>
            <p class="text-4xl font-black mt-2">@Model.Count()</p>
        </div>
        <div class="card">
            <p class="text-xs font-black uppercase tracking-widest text-text-black-soft">Đang rảnh (0 việc)</p>
            <p class="text-4xl font-black text-house-green mt-2">@Model.Count(u => u.IsAvailable)</p>
        </div>
        <div class="card">
            <p class="text-xs font-black uppercase tracking-widest text-text-black-soft">Đang bận</p>
            <p class="text-4xl font-black text-gold mt-2">@Model.Count(u => u.ActiveTasks > 0)</p>
        </div>
        <div class="card border-l-4 border-l-accent-green">
            <p class="text-xs font-black uppercase tracking-widest text-text-black-soft">Hoàn thành sớm</p>
            <p class="text-4xl font-black text-accent-green mt-2">@Model.Sum(u => u.CompletedBeforeDeadline)</p>
        </div>
    </div>

    <!-- Detailed Table -->
    <div class="card overflow-hidden !p-0">
        <div class="p-6 border-b border-black/[0.03] flex justify-between items-center bg-ceramic/10">
            <h3 class="font-bold text-house-green">Chi tiết khối lượng công việc</h3>
            <div class="flex gap-2">
                <span class="px-3 py-1 bg-starbucks-green/10 text-starbucks-green text-[10px] font-black uppercase rounded-full">Dữ liệu thời gian thực</span>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-ceramic/5">
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-text-black-soft">Nhân viên</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-text-black-soft">Trạng thái</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-text-black-soft">Tổng việc</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-text-black-soft">Đang xử lý</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-text-black-soft">Trước hạn</th>
                        <th class="p-6 text-xs font-black uppercase tracking-widest text-text-black-soft">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-black/[0.03]">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-ceramic/10 transition-colors">
                            <td class="p-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-starbucks-green/10 flex items-center justify-center text-starbucks-green font-bold">
                                        @user.FullName[0]
                                    </div>
                                    <div>
                                        <p class="font-bold text-house-green">@user.FullName</p>
                                        <p class="text-xs text-text-black-soft">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="p-6">
                                @if (user.IsAvailable)
                                {
                                    <span class="px-3 py-1 bg-blue-100 text-blue-600 rounded-full text-[10px] font-black uppercase">Đang rảnh</span>
                                }
                                else if (user.ActiveTasks > 3)
                                {
                                    <span class="px-3 py-1 bg-red-100 text-red-600 rounded-full text-[10px] font-black uppercase">Quá tải</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 bg-starbucks-green/10 text-starbucks-green rounded-full text-[10px] font-black uppercase">Đang làm việc</span>
                                }
                            </td>
                            <td class="p-6 font-bold text-house-green">@user.TotalTasks</td>
                            <td class="p-6 font-bold text-gold">@user.ActiveTasks</td>
                            <td class="p-6">
                                <div class="flex items-center gap-2">
                                    <span class="text-accent-green font-bold">@user.CompletedBeforeDeadline</span>
                                    <div class="w-16 h-1.5 bg-ceramic rounded-full overflow-hidden">
                                        <div class="h-full bg-accent-green" style="width: @(user.TotalTasks > 0 ? (user.CompletedBeforeDeadline * 100 / user.TotalTasks) : 0)%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-6">
                                <a asp-controller="Projects" asp-action="Index" class="text-starbucks-green font-bold text-sm hover:underline">Giao việc thêm</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
